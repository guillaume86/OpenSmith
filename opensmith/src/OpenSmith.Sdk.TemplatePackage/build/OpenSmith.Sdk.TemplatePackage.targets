<Project>

  <!-- Pack templates into the NuGet package -->
  <ItemGroup>
    <None Include="Templates\**\*" Pack="true" PackagePath="templates/" />
  </ItemGroup>

  <!-- Auto-detect and pack the consumer-side build targets file (custom override) -->
  <ItemGroup Condition="Exists('build\$(PackageId).targets')">
    <None Include="build\$(PackageId).targets" Pack="true" PackagePath="build/" />
  </ItemGroup>

  <!-- If no custom .targets exists, pack the generic consumer targets (renamed to match the package) -->
  <ItemGroup Condition="!Exists('build\$(PackageId).targets')">
    <None Include="$(MSBuildThisFileDirectory)OpenSmith.TemplatePackage.Consumer.targets"
          Pack="true" PackagePath="build/$(PackageId).targets" />
  </ItemGroup>

  <!-- Exclude template files from compilation -->
  <ItemGroup>
    <Compile Remove="Templates\**" />
  </ItemGroup>

</Project>
